{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "napkinbets",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-03",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "napkinbets-db",
      "database_id": "e7ea2992-e0e1-4bef-af9f-323e27c31033"
    }
  ],
  "r2_buckets": [
    {
      "binding": "BUCKET",
      "bucket_name": "napkinbets-uploads"
    }
  ],
  "routes": [
    {
      "pattern": "napkinbets.nard.uk",
      "custom_domain": true
    }
  ],
  "triggers": {
    "crons": ["* * * * *", "*/5 * * * *", "*/10 * * * *", "7 */6 * * *", "23 */12 * * *"]
  },
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "1718ecb87b7448b294bfd200718ad423",
      "preview_id": "a7581c2906fc4fcbad3b72743b4d21ce"
    }
  ]
}
