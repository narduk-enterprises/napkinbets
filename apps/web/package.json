{
  "name": "napkinbets",
  "type": "module",
  "private": true,
  "version": "1.17.2",
  "scripts": {
    "build": "nuxt build",
    "db:ready": "pnpm run db:migrate && pnpm run db:seed",
    "dev": "pnpm run db:ready && (doppler run -- nuxt dev || nuxt dev)",
    "quality": "echo 'Turbo dependsOn handles lint + typecheck + format:check'",
    "config:validate": "npx tsx ../../tools/validate-env.ts",
    "db:migrate": "bash ../../tools/db-migrate.sh napkinbets-db --local --dir drizzle",
    "db:seed": "wrangler d1 execute napkinbets-db --local --file=drizzle/seed.sql && wrangler r2 object put napkinbets-uploads/seed/venmo-1.png --local --file=drizzle/seed/venmo-1.png && wrangler r2 object put napkinbets-uploads/seed/venmo-2.png --local --file=drizzle/seed/venmo-2.png && wrangler r2 object put napkinbets-uploads/seed/venmo-rejected.png --local --file=drizzle/seed/venmo-rejected.png",
    "db:reset": "bash ../../tools/db-migrate.sh napkinbets-db --local --dir drizzle --reset && pnpm run db:seed",
    "db:studio": "drizzle-kit studio",
    "db:studio:local": "drizzle-kit studio --config=drizzle-local.config.ts",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "test:unit": "vitest run --config vitest.config.ts --project=unit",
    "test:integration": "vitest run --config vitest.config.ts --project=integration",
    "test:integration:external": "vitest run --config vitest.config.ts --project=integration-external",
    "test:integration:all": "vitest run --config vitest.config.ts --project=integration --project=integration-external",
    "test:e2e": "playwright test --config=../../playwright.config.ts",
    "test:e2e:smoke": "playwright test --project=smoke --config=../../playwright.config.ts",
    "test:e2e:auth": "playwright test --project=auth --config=../../playwright.config.ts",
    "test:e2e:guest": "playwright test --project=guest --config=../../playwright.config.ts",
    "test:e2e:dashboard": "playwright test --project=dashboard --config=../../playwright.config.ts",
    "test:e2e:events": "playwright test --project=events --config=../../playwright.config.ts",
    "test:e2e:games": "playwright test --project=games --config=../../playwright.config.ts",
    "test:e2e:groups": "playwright test --project=groups --config=../../playwright.config.ts",
    "test:e2e:napkins": "playwright test --project=napkins --config=../../playwright.config.ts",
    "test:e2e:settings": "playwright test --project=settings --config=../../playwright.config.ts",
    "test:e2e:shell": "playwright test --project=shell --config=../../playwright.config.ts",
    "test:e2e:admin": "playwright test --project=admin --config=../../playwright.config.ts",
    "test:e2e:routing": "playwright test --project=routing --config=../../playwright.config.ts",
    "format:check": "prettier --check \"**/*.{ts,mts,vue,js,mjs,json,yaml,yml,css,md}\" --ignore-path ../../.gitignore"
  },
  "dependencies": {
    "@narduk-enterprises/eslint-config": "^1.0.12",
    "@narduk-enterprises/narduk-nuxt-template-layer": "workspace:*",
    "@vueuse/core": "^14.2.1",
    "drizzle-orm": "^0.45.1",
    "h3": "^1.15.5",
    "nuxt": "^4.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nuxt/test-utils": "^4.0.0",
    "@cloudflare/workers-types": "^4.20250303.0",
    "@iconify-json/lucide": "^1.2.94",
    "@tailwindcss/vite": "^4.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.4",
    "nitro-cloudflare-dev": "^0.2.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "volta": {
    "node": "22.22.0"
  }
}
