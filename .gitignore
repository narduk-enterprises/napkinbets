# Nuxt dev/build outputs
.output
.data
.nuxt
.nitro
.cache
.turbo

# Node dependencies
node_modules

# Logs
logs
*.log

# Misc
.DS_Store
.fleet
.idea

# Local env files — use Doppler, not .env files
.env
.env.*

# Cloudflare
.wrangler/

# Drizzle local SQLite (created by drizzle-kit push)
**/drizzle/*.sqlite

# Build artifacts
*.bak

# Test artifacts
playwright-report/
test-results/
apps/web/tests/e2e/playwright-snapshots/gallery.html

# ESLint plugin build artifacts (rebuilt via `pnpm run build:plugins`)
packages/eslint-config/*/dist/
# ESLint caches
.eslint-results.json

# Prod D1 export (contains live data; do not commit)
apps/web/tools/prod-export.sql

# Secrets & credential artifacts (use Doppler, never commit these)
*-secrets.json
*.jsonl
doppler.json
doppler.yaml
lint-results.txt

# Python cache (uipro skill)
__pycache__/
.dev.vars
